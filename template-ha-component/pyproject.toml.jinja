[project]
name = "{{ project_slug }}"
version = "0.1.0"
description = "{{ description }}"
readme = "README.md"
requires-python = ">={{ python_version }}"
license = { text = "{{ license }}" }
authors = [
    { name = "{{ author_name }}", email = "{{ author_email }}" },
]

[project.urls]
Homepage = "https://github.com/{{ github_user }}/{{ project_slug }}"
Issues = "https://github.com/{{ github_user }}/{{ project_slug }}/issues"

[tool.uv]
dev-dependencies = [
    "ruff>=0.9",
    "pyright>=1.1",
    "pytest>=8",
    "pytest-asyncio>=0.24",
    "pytest-cov>=5",
    "pytest-homeassistant-custom-component>=0.13",
    "pre-commit>=4",
]

[tool.ruff]
line-length = 100
target-version = "py{{ python_version | replace('.', '') }}"

[tool.ruff.lint]
select = [
    "E", "W", "F",
    "I",
    "UP",
    "B",
    "C4",
    "ASYNC",
    "S",
    "PT",
]
ignore = ["E501"]

[tool.ruff.lint.per-file-ignores]
"tests/**/*.py" = ["S101"]

[tool.pyright]
include = ["custom_components", "tests"]
pythonVersion = "{{ python_version }}"
typeCheckingMode = "strict"

[tool.pytest.ini_options]
asyncio_mode = "auto"
addopts = "-ra -q"
