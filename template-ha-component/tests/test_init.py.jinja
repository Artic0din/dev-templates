"""Smoke tests for {{ component_friendly_name }} setup + unload."""

from __future__ import annotations

from homeassistant.core import HomeAssistant
from pytest_homeassistant_custom_component.common import MockConfigEntry

from custom_components.{{ component_slug }}.const import DOMAIN


async def test_setup_and_unload_entry(hass: HomeAssistant) -> None:
    """Config entry sets up and unloads cleanly."""
    entry = MockConfigEntry(domain=DOMAIN, data={}, title="{{ component_friendly_name }}")
    entry.add_to_hass(hass)

    assert await hass.config_entries.async_setup(entry.entry_id) is True
    await hass.async_block_till_done()
    assert entry.entry_id in hass.data.get(DOMAIN, {})

    assert await hass.config_entries.async_unload(entry.entry_id) is True
    await hass.async_block_till_done()
    assert entry.entry_id not in hass.data.get(DOMAIN, {})
