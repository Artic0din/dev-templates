#!/usr/bin/env bash
# discipline-bootstrap — orchestrate doctor + scaffold-discipline + optional PR.
#
# Usage:
#   discipline-bootstrap [path]                       # report only (calls doctor)
#   discipline-bootstrap [path] --apply               # apply scaffold if no blockers
#   discipline-bootstrap [path] --apply --open-pr     # also commit + push + draft PR

set -euo pipefail

usage() {
  cat <<EOF
Usage: discipline-bootstrap [path] [--apply] [--open-pr]

Orchestrates the discipline-doctor → scaffold-discipline → draft-PR flow.

Without --apply: runs doctor only (report).
With --apply: runs scaffold-discipline if no blockers.
With --open-pr: also creates branch chore/scaffold-discipline-stack, commits,
                pushes, and opens a draft PR.

Refuses to apply if doctor reports any blockers.
EOF
}

APPLY=0
OPEN_PR=0
TARGET="${1:-.}"

for arg in "$@"; do
  case "$arg" in
    --apply) APPLY=1 ;;
    --open-pr) OPEN_PR=1 ;;
    --help|-h) usage; exit 0 ;;
  esac
done

# Locate doctor (peer script).
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd -P)"
DOCTOR="$SCRIPT_DIR/discipline-doctor"
SCAFFOLD="$SCRIPT_DIR/scaffold-discipline"

[[ -x "$DOCTOR" ]] || { echo "ERROR: $DOCTOR not found or not executable" >&2; exit 1; }
[[ -x "$SCAFFOLD" ]] || { echo "ERROR: $SCAFFOLD not found or not executable" >&2; exit 1; }

# Run doctor in JSON mode to get classification.
if ! REPORT=$("$DOCTOR" "$TARGET" --json 2>/dev/null); then
  echo "discipline-doctor reported blockers:"
  "$DOCTOR" "$TARGET"
  exit 2
fi

# Pretty-print the report for the user.
"$DOCTOR" "$TARGET"

# Stop here if not applying.
if [[ "$APPLY" -ne 1 ]]; then
  echo ""
  echo "(Report only. Re-run with --apply to scaffold.)"
  exit 0
fi

# Parse JSON for scaffold args.
LANG=$(echo "$REPORT" | python3 -c 'import sys,json;print(json.load(sys.stdin)["scaffold_language"])')
WD=$(echo "$REPORT" | python3 -c 'import sys,json;print(json.load(sys.stdin)["working_directory"])')
PM=$(echo "$REPORT" | python3 -c 'import sys,json;print(json.load(sys.stdin)["package_manager"])')
BLOCKERS=$(echo "$REPORT" | python3 -c 'import sys,json;print(len(json.load(sys.stdin)["blockers"]))')

if [[ "$BLOCKERS" -gt 0 ]]; then
  echo "ERROR: blockers present, refusing to scaffold." >&2
  exit 2
fi

if [[ -z "$LANG" ]]; then
  echo "ERROR: doctor could not classify the stack." >&2
  exit 2
fi

# Apply scaffold.
echo ""
echo "→ applying scaffold-discipline $LANG"
cd "$TARGET"
"$SCAFFOLD" "$LANG"

# If TS+npm or monorepo, edit ci.yml caller to reflect detected values.
if [[ "$LANG" == "typescript" || "$LANG" == "node" ]]; then
  if [[ "$WD" != "." || "$PM" != "pnpm" ]]; then
    # The scaffold wrote a default caller; update it.
    CALLER=.github/workflows/ci.yml
    if [[ -f "$CALLER" ]]; then
      tmp=$(mktemp)
      sed -E \
        -e "s|working_directory: \\..*|working_directory: $WD|" \
        -e "s|package_manager: pnpm|package_manager: $PM|" \
        "$CALLER" > "$tmp" && mv "$tmp" "$CALLER"
      echo "  adjusted $CALLER: working_directory=$WD package_manager=$PM"
    fi
  fi
fi

if [[ "$OPEN_PR" -ne 1 ]]; then
  echo ""
  echo "✓ scaffold applied. Review changes, commit, push, open a draft PR manually."
  exit 0
fi

# Branch + commit + push + draft PR.
BRANCH=chore/scaffold-discipline-stack
if git show-ref --quiet "refs/heads/$BRANCH"; then
  BRANCH="${BRANCH}-$(date +%Y%m%d-%H%M%S)"
fi
git checkout -b "$BRANCH"
git add -A
git commit -m "chore(ci): scaffold discipline stack v1.3.0 ($LANG)

Generated by discipline-bootstrap.
Caller pinned to ci-core-${LANG}.yml@v1.

Co-Authored-By: discipline-bootstrap"
git push -u origin "$BRANCH"

# Open draft PR if gh CLI works.
if command -v gh >/dev/null 2>&1; then
  DEFAULT=$(git symbolic-ref --short refs/remotes/origin/HEAD 2>/dev/null | sed 's|^origin/||' || echo main)
  gh pr create --draft --base "$DEFAULT" \
    --title "chore(ci): scaffold discipline stack v1.3.0 ($LANG)" \
    --body "Auto-generated via discipline-bootstrap. Validates ci-core-${LANG}.yml@v1 against this repo. See \`Artic0din/dev-templates\`."
else
  echo "(gh CLI unavailable — open PR manually from $BRANCH against $DEFAULT)"
fi

echo ""
echo "✓ bootstrap complete."
