#!/usr/bin/env bash
# scaffold-discipline — apply v1.1.0 discipline stack to current repo
#
# Usage:   scaffold-discipline {python|typescript|swift|node}
# Reads:   ~/Claude/dev-templates/ (this checkout)
# Writes:  current repo's .github/, configs, CONTRIBUTING, AGENTS.md
#
# Idempotent. Managed files overwritten; editable files only created if missing.
# Migrates v1.0.x repos: renames .github/instructions/*.md to *.instructions.md.
# Does NOT create/modify pyproject.toml or package.json (Clarification G).

set -euo pipefail

LANGUAGE="${1:-}"
case "$LANGUAGE" in
  python|typescript|swift|node) ;;
  *)
    echo "Usage: scaffold-discipline {python|typescript|swift|node}"
    exit 1
    ;;
esac

TEMPLATES="${SCAFFOLD_TEMPLATES_DIR:-$HOME/Claude/dev-templates}"
if [[ ! -d "$TEMPLATES" ]]; then
  echo "ERROR: templates dir not found: $TEMPLATES"
  echo "Clone Artic0din/dev-templates to that location or set SCAFFOLD_TEMPLATES_DIR"
  exit 1
fi

git rev-parse --is-inside-work-tree >/dev/null 2>&1 || {
  echo "ERROR: not inside a git repo"
  exit 1
}

REPO_ROOT=$(git rev-parse --show-toplevel)
cd "$REPO_ROOT"
echo "→ scaffolding $LANGUAGE discipline v1.1.0 into $REPO_ROOT"

mkdir -p .github/workflows .github/instructions .github/prompts

# --- v1.0.x → v1.1.0 migration: rename instruction files ---

echo "  migration:"
migrated=0
for stem in meta documentation tests code-review python typescript swift node; do
  old=".github/instructions/${stem}.md"
  new=".github/instructions/${stem}.instructions.md"
  if [[ -f "$old" && ! -f "$new" ]]; then
    git mv "$old" "$new" 2>/dev/null || mv "$old" "$new"
    echo "    rename $stem.md → $stem.instructions.md"
    migrated=$((migrated + 1))
  fi
done
[[ $migrated -eq 0 ]] && echo "    (no v1.0.x instructions to rename)"

# --- Managed files (overwrite with cp -f) ---

echo "  managed:"
cp -f "$TEMPLATES/.github/instructions/meta.instructions.md"          .github/instructions/
cp -f "$TEMPLATES/.github/instructions/documentation.instructions.md" .github/instructions/
cp -f "$TEMPLATES/.github/instructions/tests.instructions.md"         .github/instructions/
cp -f "$TEMPLATES/.github/instructions/code-review.instructions.md"   .github/instructions/
cp -f "$TEMPLATES/.github/instructions/${LANGUAGE}.instructions.md"   .github/instructions/
cp -f "$TEMPLATES/.github/prompts/pr-review.prompt.md"                .github/prompts/
cp -f "$TEMPLATES/.github/workflows/security-scan.yml"                .github/workflows/
cp -f "$TEMPLATES/.github/workflows/docs-check.yml"                   .github/workflows/
cp -f "$TEMPLATES/.github/workflows/pr-title-check.yml"               .github/workflows/
cp -f "$TEMPLATES/.github/workflows/version-drift-guard.yml"          .github/workflows/
cp -f "$TEMPLATES/configs/codecov.yml"                                .
cp -f "$TEMPLATES/configs/.gitleaks.toml"                             .
echo "    .github/instructions/*.instructions.md"
echo "    .github/prompts/pr-review.prompt.md"
echo "    .github/workflows/{security-scan,docs-check,pr-title-check,version-drift-guard}.yml"
echo "    codecov.yml, .gitleaks.toml"

if [[ "$LANGUAGE" == "python" ]]; then
  cp -f "$TEMPLATES/configs/zensical.toml" .
  echo "    zensical.toml"
fi

# --- Editable files (cp -n, skip if exists) ---

echo "  editable:"
if [[ ! -f .github/workflows/ci.yml ]]; then
  sed "s/language: typescript/language: $LANGUAGE/" \
    "$TEMPLATES/workflow-templates/ci.yml" > .github/workflows/ci.yml
  echo "    .github/workflows/ci.yml (created)"
else
  echo "    .github/workflows/ci.yml (exists, skipped)"
fi

for src_dst in \
  "templates/AGENTS.md:AGENTS.md" \
  "templates/CLAUDE.md:CLAUDE.md" \
  "templates/CONTRIBUTING.md:CONTRIBUTING.md" \
  "templates/copilot-instructions.md:.github/copilot-instructions.md"; do
  src="${src_dst%%:*}"
  dst="${src_dst##*:}"
  if [[ ! -f "$dst" ]]; then
    cp "$TEMPLATES/$src" "$dst"
    echo "    $dst (created)"
  else
    echo "    $dst (exists, skipped)"
  fi
done

# --- ai-review-override label provisioning ---

echo "  label:"
if gh repo view >/dev/null 2>&1; then
  if gh label create ai-review-override \
       --description "Bypass Claude review gate (incident-mode)" \
       --color FFD700 2>/dev/null; then
    echo "    ai-review-override (created)"
  else
    echo "    ai-review-override (already exists)"
  fi
else
  echo "    [skip] no GitHub remote yet"
fi

# --- CodeRabbit + Cursor cleanup ---

echo "  cleanup:"
for f in .coderabbit.yaml .sourcery.yaml \
         .github/workflows/dual-loop-review.yml \
         .github/workflows/claude-assistant.yml \
         .github/workflows/coderabbit.yml \
         .github/workflows/coderabbit-nitpicks.yml \
         .github/workflows/claude-review.yml; do
  if [[ -f "$f" ]]; then
    rm -f "$f"
    echo "    removed $f"
  fi
done
if [[ -d .cursor ]]; then
  rm -rf .cursor
  echo "    removed .cursor/ directory"
fi

# --- Strip Cursor-only frontmatter fields from instructions if present ---

for f in .github/instructions/*.instructions.md; do
  [[ -f "$f" ]] || continue
  if grep -qE "^(globs|alwaysApply):" "$f"; then
    # In-place edit to drop Cursor fields. Keep `applyTo:` line.
    sed -i.bak -E '/^(globs|alwaysApply):/d' "$f" && rm -f "$f.bak"
    echo "    stripped Cursor fields from $(basename "$f")"
  fi
done

echo ""
echo "✓ scaffold v1.1.0 complete. Next:"
echo "  1. Review AGENTS.md (Codex role) and CLAUDE.md (builder discipline)."
echo "  2. Set branch protection on main: literal check 'CI passed'."
echo "  3. Set repo secrets if needed: ANTHROPIC_API_KEY (optional), CODECOV_TOKEN."
echo "  4. Open a draft PR to validate the stack."
