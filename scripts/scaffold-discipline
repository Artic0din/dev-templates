#!/usr/bin/env bash
# scaffold-discipline — thin wrapper around `uvx copier copy`
#
# Generates a new project from a dev-templates v2 Copier template,
# pinned to the `v2` tag of Artic0din/dev-templates.
#
# Usage:
#   scaffold-discipline <template> <dest>
#
# Templates:
#   ha-component   → Home Assistant HACS custom integration
#   python         → generic Python project (uv + ruff + pyright + pytest)
#   ts-node        → TypeScript Node project (pnpm + biome + vitest)
#   swift-ios      → Swift iOS app (deferred until 2nd Swift project)
#
# To update an existing project after the template evolves:
#   cd <existing-project>
#   uvx --from "copier>=9.5" copier update --trust
#
# Environment variables:
#   SCAFFOLD_TEMPLATES_REF   Override the pinned ref (default: v2)
#   SCAFFOLD_TEMPLATES_REPO  Override the source repo (default: https://github.com/Artic0din/dev-templates.git)

set -euo pipefail

TEMPLATE="${1:?usage: scaffold-discipline <ha-component|python|ts-node|swift-ios> <dest>}"
DEST="${2:?missing destination path}"
shift 2

REPO="${SCAFFOLD_TEMPLATES_REPO:-https://github.com/Artic0din/dev-templates.git}"
REF="${SCAFFOLD_TEMPLATES_REF:-v2}"

case "$TEMPLATE" in
  ha-component) SUB="template-ha-component" ;;
  python)       SUB="template-python" ;;
  ts-node)      SUB="template-ts-node" ;;
  swift-ios)
    echo "ERROR: template-swift-ios is deferred until a 2nd Swift project exists." >&2
    echo "Pulse uses ad-hoc setup. Scaffold blocks pending decision." >&2
    exit 2
    ;;
  *)
    echo "ERROR: unknown template: $TEMPLATE" >&2
    echo "Valid templates: ha-component | python | ts-node | swift-ios" >&2
    exit 2
    ;;
esac

if [[ -e "$DEST" && -n "$(ls -A "$DEST" 2>/dev/null)" ]]; then
  echo "ERROR: destination exists and is not empty: $DEST" >&2
  echo "For an existing project, run \`copier update\` from inside it instead." >&2
  exit 2
fi

echo "→ scaffolding $SUB → $DEST (template ref: $REF)"

exec uvx --from "copier>=9.5" copier copy \
  --trust \
  --vcs-ref "$REF" \
  --data "_template_subdirectory=$SUB" \
  "$REPO" \
  "$DEST" \
  "$@"
